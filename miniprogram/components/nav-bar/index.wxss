.nav-bar {
  display: flex;
  align-items: center;
  height: 88rpx;
  padding: 0 24rpx;
  background: #5C1A1A;
  color: #fff;
  box-sizing: border-box;
}
.nav-back {
  display: flex;
  align-items: center;
  padding: 0 8rpx;
  min-width: 100rpx;
}
.nav-arrow {
  font-size: 44rpx;
  line-height: 1;
  margin-right: 4rpx;
}
.nav-label {
  font-size: 28rpx;
}
.nav-title {
  flex: 1;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.nav-placeholder {
  min-width: 100rpx;
}
