/**
 * 和膜 HAMOREY 质保系统 — 全局样式
 */

/* ============= 品牌色 CSS 变量 ============= */
page {
  --color-primary: #5C1A1A;
  --color-primary-light: #7A2E2E;
  --color-primary-dark: #3D0F0F;
  --color-accent: #C8A96E;
  --color-accent-light: #D4BC8A;
  --color-bg: #F5F0EB;
  --color-bg-white: #FFFFFF;
  --color-bg-card: #FAF7F2;
  --color-text: #2C2C2C;
  --color-text-secondary: #666666;
  --color-text-light: #999999;
  --color-text-placeholder: #CCCCCC;
  --color-border: #E0D8CC;
  --color-border-light: #EEE8DC;
  --color-success: #4CAF50;
  --color-warning: #FF9800;
  --color-error: #E53935;
  --color-info: #2196F3;
  --radius-sm: 8rpx;
  --radius-md: 12rpx;
  --radius-lg: 16rpx;
  --radius-round: 999rpx;
  --shadow-sm: 0 2rpx 8rpx rgba(92, 26, 26, 0.06);
  --shadow-md: 0 4rpx 16rpx rgba(92, 26, 26, 0.10);
  --shadow-lg: 0 8rpx 32rpx rgba(92, 26, 26, 0.14);
  --font-xs: 22rpx;
  --font-sm: 24rpx;
  --font-md: 28rpx;
  --font-lg: 32rpx;
  --font-xl: 36rpx;
  --font-xxl: 44rpx;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC',
    'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  font-size: var(--font-md);
  color: var(--color-text);
  background-color: var(--color-bg);
  line-height: 1.6;
  box-sizing: border-box;
}

/* ============= 全局重置 ============= */
view, text, image, scroll-view, swiper, swiper-item,
input, textarea, button, navigator, checkbox, radio,
picker, form, label {
  box-sizing: border-box;
}

/* ============= 通用按钮样式 ============= */
.btn-primary {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: var(--font-lg);
  font-weight: 600;
  border-radius: var(--radius-md);
  border: none;
  transition: opacity 0.2s;
}

.btn-primary:active {
  opacity: 0.85;
}

.btn-primary[disabled] {
  background: var(--color-text-placeholder);
  color: #FFFFFF;
}

.btn-outline {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  background: transparent;
  color: var(--color-primary);
  font-size: var(--font-lg);
  font-weight: 500;
  border-radius: var(--radius-md);
  border: 2rpx solid var(--color-primary);
}

.btn-ghost {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 32rpx;
  background: transparent;
  color: var(--color-primary);
  font-size: var(--font-md);
  font-weight: 500;
  border: none;
}

.btn-sm {
  height: 60rpx;
  padding: 0 32rpx;
  font-size: var(--font-sm);
  border-radius: var(--radius-sm);
}

/* ============= 通用卡片 ============= */
.card {
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: 32rpx;
  margin: 24rpx;
  box-shadow: var(--shadow-sm);
}

.card-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 16rpx;
}

.card-subtitle {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

/* ============= 通用容器 ============= */
.page-container {
  min-height: 100vh;
  padding-bottom: 32rpx;
  background: var(--color-bg);
}

.section {
  background: var(--color-bg-white);
  margin: 24rpx;
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
}

.section-body {
  padding: 24rpx 32rpx;
}

/* ============= 通用表单 ============= */
.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  display: block;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.form-label .required {
  color: var(--color-error);
  margin-left: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  font-size: var(--font-md);
  color: var(--color-text);
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  transition: border-color 0.2s;
}

.form-input:focus {
  border-color: var(--color-primary);
}

.form-input::placeholder {
  color: var(--color-text-placeholder);
}

.form-textarea {
  width: 100%;
  min-height: 160rpx;
  padding: 20rpx 24rpx;
  font-size: var(--font-md);
  color: var(--color-text);
  background: var(--color-bg-card);
  border: 2rpx solid var(--color-border);
  border-radius: var(--radius-sm);
  line-height: 1.6;
}

/* ============= 通用标签/徽章 ============= */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  font-size: var(--font-xs);
  border-radius: var(--radius-round);
  font-weight: 500;
}

.tag-primary {
  background: rgba(92, 26, 26, 0.1);
  color: var(--color-primary);
}

.tag-success {
  background: rgba(76, 175, 80, 0.1);
  color: var(--color-success);
}

.tag-warning {
  background: rgba(255, 152, 0, 0.1);
  color: var(--color-warning);
}

.tag-error {
  background: rgba(229, 57, 53, 0.1);
  color: var(--color-error);
}

.tag-info {
  background: rgba(33, 150, 243, 0.1);
  color: var(--color-info);
}

/* ============= 状态占位 ============= */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-state-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 32rpx;
  opacity: 0.4;
}

.empty-state-text {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.6;
}

.empty-state-sub {
  font-size: var(--font-sm);
  color: var(--color-text-light);
  margin-top: 8rpx;
}

/* ============= Loading ============= */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.loading-spinner {
  width: 64rpx;
  height: 64rpx;
  border: 4rpx solid var(--color-border);
  border-top-color: var(--color-primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 24rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
}

/* ============= 错误重试 ============= */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.error-text {
  font-size: var(--font-md);
  color: var(--color-text-secondary);
  margin-bottom: 32rpx;
}

/* ============= 分割线 ============= */
.divider {
  height: 1rpx;
  background: var(--color-border-light);
  margin: 0 32rpx;
}

/* ============= 信息行 ============= */
.info-row {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
}

.info-row-label {
  width: 160rpx;
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  flex-shrink: 0;
}

.info-row-value {
  flex: 1;
  font-size: var(--font-md);
  color: var(--color-text);
}

/* ============= 安全区域底部 ============= */
.safe-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* ============= Flex 工具类 ============= */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-col {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-1 {
  flex: 1;
}

.flex-wrap {
  flex-wrap: wrap;
}

/* ============= 间距工具类 ============= */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.ml-8 { margin-left: 8rpx; }
.mr-8 { margin-right: 8rpx; }
.p-24 { padding: 24rpx; }
.p-32 { padding: 32rpx; }
.px-24 { padding-left: 24rpx; padding-right: 24rpx; }
.px-32 { padding-left: 32rpx; padding-right: 32rpx; }
.py-16 { padding-top: 16rpx; padding-bottom: 16rpx; }
.py-24 { padding-top: 24rpx; padding-bottom: 24rpx; }

/* ============= 文本 ============= */
.text-center { text-align: center; }
.text-right { text-align: right; }
.text-primary { color: var(--color-primary); }
.text-secondary { color: var(--color-text-secondary); }
.text-light { color: var(--color-text-light); }
.text-error { color: var(--color-error); }
.text-success { color: var(--color-success); }
.text-xs { font-size: var(--font-xs); }
.text-sm { font-size: var(--font-sm); }
.text-md { font-size: var(--font-md); }
.text-lg { font-size: var(--font-lg); }
.text-xl { font-size: var(--font-xl); }
.text-bold { font-weight: 600; }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
