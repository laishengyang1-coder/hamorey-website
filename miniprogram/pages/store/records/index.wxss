.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 140rpx;
}

/* 筛选栏 */
.filter-bar {
  background: var(--color-bg-white);
  padding: 16rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-search {
  margin-bottom: 12rpx;
}

.filter-input {
  width: 100%;
  height: 68rpx;
  padding: 0 24rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-round);
  font-size: var(--font-sm);
  color: var(--color-text);
}

.filter-tabs {
  display: flex;
  gap: 12rpx;
}

.filter-tab {
  padding: 8rpx 24rpx;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border-radius: var(--radius-round);
}

.filter-tab.active {
  background: var(--color-primary);
  color: #FFFFFF;
}

/* 记录卡片 */
.record-card {
  margin-bottom: 8rpx;
}

.record-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 12rpx;
}

.record-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
}

.record-plate {
  font-size: var(--font-sm);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

.record-meta {
  display: flex;
  justify-content: space-between;
  font-size: var(--font-xs);
  color: var(--color-text-light);
}

.record-code {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  margin-top: 4rpx;
}

/* 浮动按钮 */
.float-btn {
  position: fixed;
  bottom: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
}

.float-btn-text {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  background: var(--color-accent);
  color: #2C2C2C;
  font-size: var(--font-md);
  font-weight: 600;
  border-radius: var(--radius-round);
  box-shadow: 0 8rpx 24rpx rgba(200, 169, 110, 0.4);
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
}

.load-more-text {
  font-size: var(--font-sm);
  color: var(--color-text-light);
}
