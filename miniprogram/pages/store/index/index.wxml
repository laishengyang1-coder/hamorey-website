<view class="page-container">
  <!-- 门店头部 -->
  <view class="store-header">
    <view class="brand-line">和膜 HAMOREY</view>
    <view class="store-name">{{storeName}}</view>
    <view class="store-meta">{{storeCity || ''}}</view>
  </view>

  <!-- 数据概览 -->
  <view class="stats-row">
    <view class="stat-card" bindtap="goRecords">
      <view class="stat-value">{{stats.recordCount}}</view>
      <view class="stat-label">质保记录</view>
    </view>
    <view class="stat-card" bindtap="goCodes">
      <view class="stat-value">{{stats.codeCount}}</view>
      <view class="stat-label">可用质保码</view>
    </view>
    <view class="stat-card" bindtap="goPoints">
      <view class="stat-value">{{stats.points}}</view>
      <view class="stat-label">可用积分</view>
    </view>
  </view>

  <!-- 全国积分排行 -->
  <view class="rank-section" wx:if="{{nationalRanking.length > 0}}">
    <view class="section-title">全国积分排行</view>

    <!-- 自店排名 -->
    <view class="my-rank-card" wx:if="{{myRank && myRank.points > 0}}">
      <view class="my-rank-index">{{myRank.rank > 99 ? '99+' : myRank.rank}}</view>
      <view class="my-rank-info">
        <view class="my-rank-name">{{myRank.name}}</view>
        <view class="my-rank-label">我的排名</view>
      </view>
      <view class="my-rank-points">{{myRank.points}}<text class="my-rank-unit">积分</text></view>
    </view>

    <view class="rank-card">
      <view class="rank-item" wx:for="{{nationalRanking}}" wx:key="name" wx:if="{{index < 10}}">
        <view class="rank-index {{index < 3 ? 'rank-top' : ''}}">{{index + 1}}</view>
        <view class="rank-name">{{item.name}}<text wx:if="{{item.province}}" class="rank-sub-info"> {{item.province}} · {{item.city || ''}}</text></view>
        <view class="rank-count">{{item.count}}<text class="rank-unit">积分</text></view>
      </view>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="section-title mb-24">快捷操作</view>
    <view class="action-grid">
      <view class="action-item" bindtap="goRegister">
        <image class="action-icon" src="/images/icon-register.png" mode="aspectFit" />
        <view class="action-text">登记质保</view>
      </view>
      <view class="action-item" bindtap="goRecords">
        <image class="action-icon" src="/images/tab-record-active.png" mode="aspectFit" />
        <view class="action-text">质保记录</view>
      </view>
      <view class="action-item" bindtap="goCodes">
        <image class="action-icon" src="/images/tab-code-active.png" mode="aspectFit" />
        <view class="action-text">质保码</view>
      </view>
      <view class="action-item" bindtap="goPoints">
        <image class="action-icon" src="/images/tab-points-active.png" mode="aspectFit" />
        <view class="action-text">积分</view>
      </view>
      <view class="action-item" bindtap="goRewards">
        <image class="action-icon" src="/images/icon-gift.png" mode="aspectFit" />
        <view class="action-text">积分商城</view>
      </view>
      <view class="action-item" bindtap="goOrders">
        <image class="action-icon" src="/images/icon-box.png" mode="aspectFit" />
        <view class="action-text">兑换记录</view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-wrap">
    <view class="logout-btn" bindtap="handleLogout">退出登录</view>
  </view>
</view>
