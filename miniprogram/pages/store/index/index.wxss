.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 140rpx;
}

/* 门店头部 */
.store-header {
  background: linear-gradient(135deg, #5C1A1A 0%, #7A2E2E 100%);
  padding: 48rpx 32rpx 56rpx;
  color: #FFFFFF;
}

.brand-line {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-bottom: 16rpx;
}

.store-name {
  font-size: var(--font-xl);
  font-weight: 700;
  margin-bottom: 8rpx;
}

.store-meta {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.7);
}

/* 数据概览 */
.stats-row {
  display: flex;
  margin: -32rpx 24rpx 24rpx;
  position: relative;
  z-index: 1;
}

.stat-card {
  flex: 1;
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: 28rpx 16rpx;
  text-align: center;
  margin: 0 8rpx;
  box-shadow: var(--shadow-md);
}

.stat-value {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

/* 快捷入口 */
.quick-actions {
  margin: 24rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.action-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 0;
  border-right: 1rpx solid var(--color-border-light);
  border-bottom: 1rpx solid var(--color-border-light);
}

.action-item:nth-child(3n) {
  border-right: none;
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 14rpx;
}

.action-text {
  font-size: var(--font-sm);
  color: var(--color-text);
}

/* 排行榜 */
.rank-section {
  margin: 24rpx;
}

.rank-card {
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: 8rpx 0;
}

.rank-item {
  display: flex;
  align-items: center;
  padding: 20rpx 28rpx;
  border-bottom: 1rpx solid var(--color-border-light);
}

.rank-item:last-child {
  border-bottom: none;
}

.rank-index {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--color-border-light);
  color: var(--color-text-secondary);
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.rank-index.rank-top {
  background: var(--color-primary);
  color: #FFFFFF;
}

.rank-name {
  flex: 1;
  margin: 0 20rpx;
  font-size: var(--font-sm);
  color: var(--color-text);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-sub-info {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  margin-left: 8rpx;
}

.rank-count {
  font-size: var(--font-sm);
  font-weight: 700;
  color: var(--color-primary);
}

.rank-unit {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  font-weight: 400;
  margin-left: 4rpx;
}

/* 自店排名卡片 */
.my-rank-card {
  display: flex;
  align-items: center;
  background: #FBF5EC;
  border: 2rpx solid #E8D5B7;
  border-radius: var(--radius-md);
  padding: 20rpx 28rpx;
  margin-bottom: 16rpx;
}

.my-rank-index {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: var(--color-primary);
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.my-rank-info {
  flex: 1;
  margin-left: 20rpx;
}

.my-rank-name {
  font-size: var(--font-sm);
  font-weight: 600;
  color: var(--color-primary);
}

.my-rank-label {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  margin-top: 4rpx;
}

.my-rank-points {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--color-primary);
}

.my-rank-unit {
  font-size: var(--font-xs);
  color: var(--color-text-light);
  font-weight: 400;
  margin-left: 4rpx;
}

/* 退出按钮 */
.logout-wrap {
  padding: 24rpx 48rpx 48rpx;
}

.logout-btn {
  text-align: center;
  padding: 24rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  background: var(--color-bg-white);
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}
