.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 140rpx;
}

/* 门店头部 */
.store-header {
  background: linear-gradient(135deg, #5C1A1A 0%, #7A2E2E 100%);
  padding: 48rpx 32rpx;
  color: #FFFFFF;
}

.store-name {
  font-size: var(--font-xl);
  font-weight: 700;
  margin-bottom: 8rpx;
}

.store-meta {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.7);
}

/* 数据概览 */
.stats-row {
  display: flex;
  margin: -32rpx 24rpx 24rpx;
  position: relative;
  z-index: 1;
}

.stat-card {
  flex: 1;
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: 24rpx 16rpx;
  text-align: center;
  margin: 0 8rpx;
  box-shadow: var(--shadow-md);
}

.stat-value {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  margin-top: 4rpx;
}

/* 快捷入口 */
.quick-actions {
  margin: 24rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  overflow: hidden;
}

.action-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0;
  border-right: 1rpx solid var(--color-border-light);
  border-bottom: 1rpx solid var(--color-border-light);
}

.action-item:nth-child(3n) {
  border-right: none;
}

.action-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.action-text {
  font-size: var(--font-sm);
  color: var(--color-text);
}

/* 退出按钮 */
.logout-btn {
  display: flex;
  justify-content: center;
  padding: 48rpx;
  font-size: var(--font-sm);
  color: var(--color-text-light);
}
