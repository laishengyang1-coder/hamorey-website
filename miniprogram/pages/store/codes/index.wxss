.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 40rpx;
}

.filter-bar {
  background: var(--color-bg-white);
  padding: 16rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.filter-search {
  margin-bottom: 12rpx;
}

.filter-input {
  width: 100%;
  height: 68rpx;
  padding: 0 24rpx;
  background: var(--color-bg-card);
  border-radius: var(--radius-round);
  font-size: var(--font-sm);
  color: var(--color-text);
}

.filter-tabs {
  display: flex;
  gap: 12rpx;
}

.filter-tab {
  padding: 8rpx 24rpx;
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border-radius: var(--radius-round);
}

.filter-tab.active {
  background: var(--color-primary);
  color: #FFFFFF;
}

.code-card {
  margin-bottom: 8rpx;
}

.code-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.code-value {
  font-size: var(--font-lg);
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 2rpx;
}

.code-meta {
  display: flex;
  justify-content: space-between;
  font-size: var(--font-xs);
  color: var(--color-text-light);
}

.load-more {
  text-align: center;
  padding: 32rpx;
}

.load-more-text {
  font-size: var(--font-sm);
  color: var(--color-text-light);
}
