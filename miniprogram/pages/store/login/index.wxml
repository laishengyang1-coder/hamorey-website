<view class="page-container">
  <!-- 品牌头部 -->
  <view class="login-header">
    <view class="login-logo">HAMOREY</view>
    <view class="login-subtitle">门店管理系统</view>
  </view>

  <!-- 登录表单 -->
  <view class="login-form">
    <view class="form-group">
      <view class="form-label">用户名</view>
      <input
        class="form-input"
        placeholder="请输入用户名"
        placeholder-class="search-placeholder"
        value="{{username}}"
        bindinput="onUsernameInput"
      />
    </view>

    <view class="form-group">
      <view class="form-label">密码</view>
      <input
        class="form-input"
        type="password"
        placeholder="请输入密码"
        placeholder-class="search-placeholder"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <view class="form-group mt-32">
      <button
        class="btn-primary"
        loading="{{submitting}}"
        disabled="{{submitting || !username || !password}}"
        bindtap="handleLogin"
      >{{submitting ? '登录中...' : '登录'}}</button>
    </view>

    <!-- 省代入口 -->
    <view class="switch-entry" bindtap="goProvinceLogin">
      <text>省代登录 ›</text>
    </view>
  </view>
</view>
