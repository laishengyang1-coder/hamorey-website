<view class="quote-page">
  <!-- Loading -->
  <view wx:if="{{loading}}" class="loading-container">
    <view class="loading-spinner"></view>
    <view class="loading-text">加载报价中...</view>
  </view>

  <!-- Error -->
  <view wx:elif="{{error}}" class="error-container">
    <view class="error-icon">😞</view>
    <view class="error-text">{{error}}</view>
    <view class="retry-btn" bindtap="loadAllPrices">重试</view>
  </view>

  <!-- 报价内容 -->
  <block wx:else>
    <!-- 产品大类 Tab -->
    <scroll-view class="category-bar" scroll-x="true" enhanced="true" show-scrollbar="false">
      <view
        class="cat-chip {{activeCategory === item.cat ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:key="cat"
        data-cat="{{item.cat}}"
        bindtap="switchCategory"
      >{{item.label}}</view>
    </scroll-view>

    <!-- 型号选择栏 -->
    <view class="model-bar" bindtap="toggleModelPicker">
      <view class="model-bar-left">
        <text class="model-bar-label">型号</text>
        <text class="model-bar-name">{{activeModelName || activeModel || '选择型号'}}</text>
      </view>
      <view class="model-bar-arrow {{showModelPicker ? 'up' : ''}}">▼</view>
    </view>

    <!-- 型号下拉 -->
    <view class="model-dropdown" wx:if="{{showModelPicker}}">
      <view
        class="model-option {{activeModel === item.code ? 'active' : ''}}"
        wx:for="{{categories}}"
        wx:for-item="catData"
        wx:key="cat"
        wx:if="{{catData.cat === activeCategory}}"
      >
        <block wx:for="{{catData.models}}" wx:key="code">
          <view class="model-option-row" data-code="{{item.code}}" data-name="{{item.name}}" bindtap="onPickModel">
            <text class="model-option-name">{{item.name}}</text>
            <text class="model-option-check" wx:if="{{activeModel === item.code}}">✓</text>
          </view>
        </block>
      </view>
    </view>
    <view class="model-overlay" wx:if="{{showModelPicker}}" bindtap="toggleModelPicker"></view>

    <!-- 报价提示 -->
    <view class="quote-tip" wx:if="{{groupedParts.length > 0}}">勾选部位查看预估总额（元）</view>

    <!-- 部位列表（按区域分组） -->
    <view class="parts-section" wx:if="{{groupedParts.length > 0}}">
      <block wx:for="{{groupedParts}}" wx:for-index="gi" wx:key="group">
        <view class="part-group">
          <view class="group-header">
            <view class="group-title">{{item.group}}</view>
            <view class="group-select" data-gi="{{gi}}" bindtap="toggleGroupAll">{{item.groupChecked ? '取消全选' : '全选'}}</view>
          </view>
          <view
            class="part-row"
            wx:for="{{item.parts}}"
            wx:for-item="part"
            wx:key="id"
            data-gi="{{gi}}"
            data-pi="{{index}}"
            bindtap="togglePart"
          >
            <view class="part-left">
              <view class="checkbox-box {{part.checked ? 'checked' : ''}}">
                <text wx:if="{{part.checked}}">✓</text>
              </view>
              <view class="part-name">{{part.part_name}}</view>
            </view>
            <view class="part-price">¥{{part.price_fmt}}</view>
          </view>
        </view>
      </block>
    </view>

    <!-- 汇总 -->
    <view class="summary-bar" wx:if="{{selectedParts.length > 0}}">
      <view class="summary-info">
        <text class="summary-count">{{selectedParts.length}} 项</text>
        <text class="summary-total">¥{{totalPrice}}</text>
      </view>
      <view class="summary-note">*参考报价，以门店核定为准</view>
    </view>

    <view class="empty-hint" wx:else>
      <text>👆 选择大类与型号后勾选部位查看报价</text>
    </view>
  </block>
</view>
