<view class="page-container">
  <!-- 全屏背景图轮播：铺满屏幕，自动切换 -->
  <swiper class="page-bg-swiper" indicator-dots="{{true}}" autoplay="{{true}}" circular="{{true}}" interval="{{5000}}" duration="{{800}}" indicator-color="rgba(255,255,255,0.3)" indicator-active-color="#FFFFFF">
    <swiper-item wx:for="{{bgList}}" wx:key="*this">
      <image class="page-bg" src="{{item}}" mode="aspectFill" />
    </swiper-item>
  </swiper>
  <view class="page-bg-overlay"></view>

  <!-- 内容层 -->
  <view class="page-content">
    <!-- 顶部品牌区 -->
    <view class="brand-header">
      <image class="brand-logo-img" src="/images/logo.jpg" mode="aspectFit" />
      <view class="brand-slogan">和膜 不止于膜</view>
      <view class="brand-subtitle">HAMOREY 质保查询系统</view>
    </view>

    <!-- 搜索区域 -->
    <view class="search-section">
      <view class="search-card">
        <input
          class="search-input"
          type="text"
          maxlength="50"
          placeholder="请输入完整的手机号码 / 车架号 / 车牌号"
          placeholder-class="search-placeholder"
          value="{{keyword}}"
          bindinput="onKeywordInput"
          bindconfirm="doSearch"
          focus="{{true}}"
        />
      </view>
      <view class="search-btn" bindtap="doSearch">
        <text class="search-btn-text">查询</text>
      </view>
      <view class="search-hint">系统将自动识别查询类型</view>
    </view>

    <!-- 底部区域 -->
    <view class="footer-section">
      <view class="store-entry" bindtap="goStoreLogin">
        <text class="store-entry-icon">🏪</text>
        <text class="store-entry-text">门店 / 省代登录</text>
        <text class="store-entry-arrow">›</text>
      </view>

      <view class="brand-footer">
        <text class="brand-footer-text">和膜 HAMOREY · 汽车漆面保护膜质保系统</text>
      </view>

      <view class="disclaimer">
        <view class="disclaimer-title">1. 免责声明</view>
        <view class="disclaimer-text">
          ① 因不可抗力、外力撞击、强酸碱腐蚀、不当保养或人为损坏导致的车体及膜面损伤，和膜及施工单位不承担相关责任。
        </view>
      </view>
    </view>
  </view>
</view>
