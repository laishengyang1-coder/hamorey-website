.page-container {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000000;
  overflow: hidden;
}

/* 全屏背景轮播：铺满整个屏幕，无黑边 */
.page-bg-swiper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 0;
  background: #000000;
}

.page-bg-swiper .page-bg {
  width: 100%;
  height: 100%;
  /* aspectFill 会等比缩放并裁剪溢出部分，保证不留黑边 */
  /* 此组合写真壁纸比例与竖屏手机接近，裁切幅度小 */
}

.page-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 1;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.45) 0%,
    rgba(0, 0, 0, 0.2) 35%,
    rgba(0, 0, 0, 0.65) 70%,
    rgba(0, 0, 0, 0.85) 100%
  );
}

/* 内容层 */
.page-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-top: 48rpx;
}

/* 品牌头部 */
.brand-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 48rpx 20rpx;
}

.brand-logo-box {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.brand-logo-icon {
  width: 56rpx;
  height: 56rpx;
  background: #FFFFFF;
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.logo-shape {
  width: 30rpx;
  height: 30rpx;
  background: var(--color-primary);
  border-radius: 5rpx;
  transform: rotate(45deg);
}

.brand-logo-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 6rpx;
}

.brand-slogan {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  margin-bottom: 12rpx;
  font-style: italic;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
}

.brand-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 3rpx;
}

/* 搜索区域 — 下 1/3 偏下位置 */
.search-section {
  padding: 0 72rpx;
  margin-top: 40vh;
}

.search-card {
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.search-input {
  width: 100%;
  height: 64rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #2C2C2C;
  text-align: center;
}

.search-placeholder {
  color: #AAAAAA;
  font-size: 24rpx;
  text-align: center;
}

.search-btn {
  margin-top: 20rpx;
  width: 100%;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1E5AF5;
  border-radius: 999rpx;
  box-shadow: 0 6rpx 18rpx rgba(30, 90, 245, 0.3);
}

.search-btn:active {
  opacity: 0.9;
}

.search-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.search-hint {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 16rpx;
}

/* 底部区域 — 降低透明度，避免明显黑块 */
.footer-section {
  background: rgba(0, 0, 0, 0.38);
  padding: 36rpx 48rpx 36rpx;
  margin-top: auto;
}

.store-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 0;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.store-entry-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.store-entry-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.store-entry-arrow {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-left: 6rpx;
}

/* 免责声明：极小字，置于最底一行 */
.disclaimer {
  margin-bottom: 12rpx;
}

.disclaimer-title {
  font-size: 18rpx;
  font-weight: 400;
  color: rgba(255, 255, 255, 0.35);
  margin-bottom: 4rpx;
}

.disclaimer-text {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.32);
  line-height: 1.5;
  text-align: justify;
}

.brand-footer {
  display: flex;
  justify-content: center;
}

.brand-footer-text {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.28);
  letter-spacing: 2rpx;
}

/* 废弃的 tab 样式（保留兼容） */
.search-tabs,
.search-tab {
  display: none;
}

.search-input-area,
.search-btn-inline {
  display: none;
}
