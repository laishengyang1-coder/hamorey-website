.page-container {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000000;
  overflow: hidden;
}

/* 上半屏背景图：参考图布局，图片占上半屏 */
.page-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 72vh;
  z-index: 0;
}

.page-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 78vh;
  z-index: 1;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.35) 0%,
    rgba(0, 0, 0, 0.15) 35%,
    rgba(0, 0, 0, 0.55) 70%,
    #000000 100%
  );
}

/* 内容层 */
.page-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-top: 48rpx;
}

/* 品牌头部 */
.brand-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 56rpx;
}

.brand-logo-box {
  display: flex;
  align-items: center;
  margin-bottom: 40rpx;
}

.brand-logo-icon {
  width: 64rpx;
  height: 64rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.logo-shape {
  width: 36rpx;
  height: 36rpx;
  background: var(--color-primary);
  border-radius: 6rpx;
  transform: rotate(45deg);
}

.brand-logo-text {
  font-size: 48rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 8rpx;
}

.brand-slogan {
  font-size: 52rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  margin-bottom: 16rpx;
  font-style: italic;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.5);
}

.brand-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 4rpx;
}

/* 搜索区域 */
.search-section {
  padding: 0 56rpx;
  margin-bottom: auto;
}

.search-card {
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 12rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.25);
}

.search-input {
  width: 100%;
  height: 80rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #2C2C2C;
  text-align: center;
}

.search-placeholder {
  color: #AAAAAA;
  font-size: 26rpx;
  text-align: center;
}

.search-btn {
  margin-top: 32rpx;
  width: 100%;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #1E5AF5;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 24rpx rgba(30, 90, 245, 0.35);
}

.search-btn:active {
  opacity: 0.9;
}

.search-btn-text {
  font-size: 34rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 6rpx;
}

.search-hint {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 24rpx;
}

/* 底部黑色区域 */
.footer-section {
  background: #000000;
  padding: 32rpx 48rpx 48rpx;
}

.store-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  margin-bottom: 32rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.store-entry-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.store-entry-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

.store-entry-arrow {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-left: 8rpx;
}

.disclaimer {
  margin-bottom: 32rpx;
}

.disclaimer-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 12rpx;
}

.disclaimer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.55);
  line-height: 1.7;
  text-align: justify;
}

.brand-footer {
  display: flex;
  justify-content: center;
}

.brand-footer-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.35);
  letter-spacing: 2rpx;
}

/* 废弃的 tab 样式（保留兼容） */
.search-tabs,
.search-tab {
  display: none;
}

.search-input-area,
.search-btn-inline {
  display: none;
}
