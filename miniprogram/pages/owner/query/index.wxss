.page-container {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  padding-bottom: 0;
  overflow: hidden;
}

/* 全屏背景图 */
.page-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.page-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(54, 14, 14, 0.82) 0%, rgba(30, 5, 5, 0.65) 40%, rgba(12, 2, 2, 0.55) 100%);
  z-index: 1;
}

/* 内容层 */
.page-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* 品牌头部 */
.brand-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 48rpx 60rpx;
}

.brand-logo-text {
  font-size: 64rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 10rpx;
  margin-bottom: 16rpx;
  text-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.4);
}

.brand-subtitle {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.85);
  letter-spacing: 4rpx;
  text-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.3);
}

/* 搜索区域 */
.search-section {
  flex: 1;
  padding: 0 48rpx;
}

.search-input-area {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.96);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.35);
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.search-input {
  flex: 1;
  height: 100rpx;
  padding: 0 32rpx;
  font-size: var(--font-lg);
  color: var(--color-text);
}

.search-placeholder {
  color: var(--color-text-placeholder);
  font-size: var(--font-md);
}

.search-btn {
  width: 160rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-accent);
}

.search-btn-text {
  font-size: var(--font-lg);
  font-weight: 600;
  color: #2C2C2C;
}

/* 门店入口 */
.store-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 48rpx;
  margin-top: auto;
  background: rgba(255, 255, 255, 0.08);
  border-radius: var(--radius-md) var(--radius-md) 0 0;
  backdrop-filter: blur(8rpx);
  margin: 48rpx;
}

.store-entry-icon {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.store-entry-text {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.85);
}

.store-entry-arrow {
  font-size: 32rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-left: 4rpx;
}

/* 底部 */
.brand-footer {
  display: flex;
  justify-content: center;
  padding: 32rpx 48rpx 64rpx;
}

.brand-footer-text {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 2rpx;
}

/* 搜索提示 */
.search-hint {
  text-align: center;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.65);
  margin-top: 16rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
}

/* 废弃的 tab 样式（保留兼容） */
.search-tabs {
  display: flex;
  margin-bottom: 32rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: var(--radius-round);
  padding: 6rpx;
}

.search-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 0;
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.6);
  border-radius: var(--radius-round);
  transition: all 0.2s;
}

.search-tab.active {
  background: var(--color-accent);
  color: #2C2C2C;
  font-weight: 600;
}
