/* 和膜 HAMOREY 品牌首页样式 */
.home-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

/* 顶部品牌区 + 搜索 */
.home-header {
  background: var(--color-primary);
  padding: 32rpx 32rpx 48rpx;
  border-radius: 0 0 32rpx 32rpx;
  box-shadow: var(--shadow-md);
}

.brand-row {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.brand-logo {
  width: 84rpx;
  height: 84rpx;
  margin-right: 20rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 8rpx;
}

.brand-text {
  flex: 1;
}

.brand-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.brand-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 6rpx;
}

.home-search-bar {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 8rpx 8rpx 8rpx 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.search-icon {
  font-size: 28rpx;
  color: var(--color-text-light);
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  height: 64rpx;
  font-size: 26rpx;
  color: var(--color-text);
}

.search-placeholder {
  color: var(--color-text-placeholder);
  font-size: 26rpx;
}

.scan-icon {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  margin-right: 8rpx;
}

.scan-icon-text {
  font-size: 32rpx;
  color: var(--color-text-secondary);
}

.search-btn {
  height: 64rpx;
  padding: 0 32rpx;
  background: var(--color-primary);
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.search-btn:active {
  opacity: 0.85;
}

/* Banner 轮播 */
.banner-section {
  margin: 28rpx 32rpx 0;
}

.banner-swiper {
  height: 920rpx;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: var(--shadow-md);
}

.banner-item {
  position: relative;
  width: 100%;
  height: 100%;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    135deg,
    rgba(44, 20, 18, 0.72) 0%,
    rgba(44, 20, 18, 0.28) 45%,
    rgba(44, 20, 18, 0.55) 100%
  );
}

.banner-content {
  position: absolute;
  left: 28rpx;
  bottom: 28rpx;
  right: 28rpx;
}

.banner-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  background: var(--color-accent);
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: 600;
  border-radius: 8rpx;
  margin-bottom: 14rpx;
}

.banner-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.banner-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

/* 2x2 功能入口 */
.function-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
  margin: 28rpx 32rpx 0;
}

.function-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border-light);
}

.function-card:active {
  opacity: 0.9;
  transform: scale(0.98);
}

.function-info {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.function-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 6rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.function-subtitle {
  font-size: 20rpx;
  color: var(--color-text-light);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.function-icon {
  width: 88rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.function-icon-img {
  width: 72rpx;
  height: 72rpx;
}

/* 内容模块 */
.section {
  margin: 36rpx 32rpx 0;
}

.section-header {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.section-header.center {
  justify-content: center;
  text-align: center;
}

.section-title {
  display: flex;
  flex-direction: column;
}

.section-title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.2;
}

.section-title-en {
  font-size: 20rpx;
  color: var(--color-text-light);
  letter-spacing: 2rpx;
  margin-top: 4rpx;
}

.section-more {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: var(--color-primary);
  font-weight: 500;
  padding: 6rpx 0;
}

.section-more-arrow {
  font-size: 30rpx;
  margin-left: 4rpx;
  line-height: 1;
}

/* 施工案例横向滚动 */
.case-scroll {
  width: 100%;
  white-space: nowrap;
}

.case-list {
  display: inline-flex;
  padding: 4rpx 0 8rpx;
}

.case-card {
  position: relative;
  width: 480rpx;
  height: 280rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-right: 20rpx;
  flex-shrink: 0;
  box-shadow: var(--shadow-sm);
}

.case-card:last-child {
  margin-right: 0;
}

.case-image {
  width: 100%;
  height: 100%;
}

.case-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.1) 0%,
    rgba(0, 0, 0, 0.6) 100%
  );
}

.case-content {
  position: absolute;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
}

.case-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
}

.case-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.4);
}

/* 产品系列 2x2 */
.series-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.series-card {
  position: relative;
  height: 260rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.series-image {
  width: 100%;
  height: 100%;
}

.series-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(44, 20, 18, 0.55) 0%,
    rgba(44, 20, 18, 0.78) 100%
  );
}

.series-content {
  position: absolute;
  left: 20rpx;
  right: 20rpx;
  bottom: 20rpx;
}

.series-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.series-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 4rpx;
}

.series-subtitle {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 1rpx;
  margin-bottom: 8rpx;
}

.series-desc {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 品牌介绍 */
.brand-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--color-border-light);
}

.brand-content {
  flex: 1;
  margin-right: 20rpx;
}

.brand-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-primary);
  margin-bottom: 14rpx;
}

.brand-paragraph {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  margin-bottom: 10rpx;
}

.brand-paragraph:last-child {
  margin-bottom: 0;
}

.brand-image {
  width: 160rpx;
  height: 160rpx;
  flex-shrink: 0;
  opacity: 0.9;
}

/* 授权门店 */
.store-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-md);
}

.store-card-content {
  flex: 1;
  margin-right: 20rpx;
}

.store-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.store-card-desc {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.5;
}

.store-card-arrow {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
  font-size: 32rpx;
  color: #FFFFFF;
}

/* 免责声明 */
.disclaimer-section {
  margin: 36rpx 32rpx 0;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.6);
  border-radius: 16rpx;
}

.disclaimer-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 8rpx;
}

.disclaimer-text {
  font-size: 20rpx;
  color: var(--color-text-light);
  line-height: 1.6;
}

/* 底部安全区占位 */
.safe-bottom-placeholder {
  height: 140rpx;
}

/* 登录态提示（可选） */
.role-badge {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 14rpx;
  background: var(--color-accent);
  color: #FFFFFF;
  font-size: 20rpx;
  border-radius: 8rpx;
  margin-left: 12rpx;
}
