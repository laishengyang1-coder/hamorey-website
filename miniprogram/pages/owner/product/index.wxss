.product-page {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}

.product-hero {
  position: relative;
  height: 360rpx;
  overflow: hidden;
}

.hero-image {
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(
    180deg,
    rgba(44, 20, 18, 0.45) 0%,
    rgba(44, 20, 18, 0.78) 100%
  );
}

.hero-content {
  position: absolute;
  left: 32rpx;
  bottom: 32rpx;
}

.hero-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}

.hero-subtitle {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  letter-spacing: 2rpx;
}

/* 系列切换 */
.series-tabs {
  display: flex;
  padding: 24rpx 32rpx;
  gap: 16rpx;
  overflow-x: auto;
  background: var(--color-bg);
}

.series-tab {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-width: 140rpx;
  padding: 18rpx 20rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  border: 2rpx solid transparent;
  box-shadow: var(--shadow-sm);
}

.series-tab.active {
  border-color: var(--color-primary);
  background: var(--color-primary);
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 6rpx;
}

.series-tab.active .tab-icon,
.series-tab.active .tab-text {
  color: #FFFFFF;
}

.tab-text {
  font-size: 22rpx;
  color: var(--color-text);
  font-weight: 500;
  white-space: nowrap;
}

/* 产品详情 */
.product-detail {
  padding: 0 32rpx;
}

.detail-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: var(--shadow-sm);
  margin-bottom: 24rpx;
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.detail-subtitle {
  font-size: 20rpx;
  color: var(--color-text-light);
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
}

.detail-desc {
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
}

.feature-list {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.feature-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: var(--shadow-sm);
}

.feature-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.feature-text {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* 操作按钮 */
.action-bar {
  padding: 0 32rpx 32rpx;
}

.action-btn {
  margin-bottom: 20rpx;
  height: 88rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-outline {
  background: transparent;
  color: var(--color-primary);
  border: 2rpx solid var(--color-primary);
}

.btn-outline:active {
  background: rgba(92, 26, 26, 0.06);
}

.safe-bottom-placeholder {
  height: 140rpx;
}
