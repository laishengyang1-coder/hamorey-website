/* 质保条款页 — 和膜 HAMOREY 有限质保条款 */

.terms-page {
  min-height: 100vh;
  background: #FEFAF8;
  padding-bottom: calc(100rpx + env(safe-area-inset-bottom));
}

/* 顶部标题区 */
.terms-hero {
  background: linear-gradient(180deg, #5C1A1A 0%, #7A2E2E 100%);
  padding: 44rpx 32rpx 36rpx;
  color: #FFFFFF;
}

.terms-hero-title {
  font-size: 44rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  margin-bottom: 6rpx;
}

.terms-hero-subtitle {
  font-size: 30rpx;
  font-weight: 500;
  letter-spacing: 6rpx;
  margin-bottom: 22rpx;
  padding-bottom: 22rpx;
  border-bottom: 2rpx solid rgba(255,255,255,0.2);
}

.terms-hero-desc {
  font-size: 26rpx;
  line-height: 42rpx;
  color: rgba(255,255,255,0.85);
}

/* 三点摘要 */
.terms-highlights {
  display: flex;
  justify-content: space-around;
  padding: 22rpx 16rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0EBE7;
  flex-wrap: wrap;
  gap: 8rpx;
}

.highlight-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 8rpx;
}

.highlight-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #C8A96E;
  flex-shrink: 0;
}

.highlight-text {
  font-size: 22rpx;
  color: #5C1A1A;
  font-weight: 500;
  white-space: nowrap;
}

/* 条款正文容器 */
.terms-body {
  padding: 0 28rpx 20rpx;
}

/* 每条条款 */
.terms-section {
  margin-top: 28rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(92,26,26,0.04);
}

.section-heading {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-bottom: 18rpx;
  border-bottom: 2rpx solid #F5EDE9;
}

.section-num {
  width: 44rpx;
  height: 44rpx;
  border-radius: 10rpx;
  background: #5C1A1A;
  color: #FFFFFF;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1A1412;
  letter-spacing: 1rpx;
}

.section-text {
  font-size: 28rpx;
  line-height: 44rpx;
  color: #2D221E;
  margin-bottom: 16rpx;
}

/* 列表 */
.terms-list-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #5C1A1A;
  margin-bottom: 12rpx;
}

.terms-list {
  margin-bottom: 12rpx;
}

.terms-list-item {
  font-size: 26rpx;
  line-height: 42rpx;
  color: #4A3A34;
  padding: 8rpx 0 8rpx 30rpx;
  position: relative;
}

.terms-list-item::before {
  content: '';
  position: absolute;
  left: 10rpx;
  top: 18rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #C8A96E;
}

/* 覆盖内容卡片 */
.coverage-item {
  background: #FDF9F5;
  border-radius: 12rpx;
  padding: 18rpx 22rpx;
  margin-bottom: 12rpx;
  border-left: 6rpx solid #5C1A1A;
}

.coverage-label {
  font-size: 26rpx;
  font-weight: 700;
  color: #5C1A1A;
  margin-bottom: 4rpx;
}

.coverage-desc {
  font-size: 24rpx;
  line-height: 38rpx;
  color: #4A3A34;
}

/* 表格分类标题 */
.table-category {
  font-size: 26rpx;
  font-weight: 700;
  color: #5C1A1A;
  margin: 24rpx 0 12rpx;
  padding-left: 8rpx;
  border-left: 4rpx solid #C8A96E;
}

/* 表格 */
.terms-table {
  border-radius: 12rpx;
  overflow: hidden;
  border: 1rpx solid #E8E0DA;
  margin-bottom: 8rpx;
}

.table-header {
  display: flex;
  background: #5C1A1A;
}

.table-header > view {
  padding: 14rpx 16rpx;
  font-size: 24rpx;
  font-weight: 600;
  color: #FFFFFF;
}

.table-row {
  display: flex;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F5EDE9;
}

.table-row:last-child {
  border-bottom: none;
}

.table-row.alt {
  background: #FDF9F5;
}

.table-row > view {
  padding: 13rpx 16rpx;
  font-size: 24rpx;
  line-height: 36rpx;
}

.table-col-name {
  flex: 3;
  color: #2D221E;
}

.table-col-period {
  flex: 1;
  text-align: center;
  color: #C8A96E;
  font-weight: 700;
}

.table-note {
  font-size: 22rpx;
  line-height: 36rpx;
  color: #9E8A82;
  padding: 12rpx 4rpx 0;
}

/* 底部占位 */
.safe-bottom-placeholder {
  height: 20rpx;
}
