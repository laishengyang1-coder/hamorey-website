.cases-page {
  min-height: 100vh;
  background: #FEFAF8;
  padding-bottom: 40rpx;
}

.cases-hero {
  background: linear-gradient(180deg, #5C1A1A, #7A2E2E);
  padding: 36rpx 32rpx;
  color: #FFFFFF;
}

.cases-hero-title {
  font-size: 36rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  margin-bottom: 6rpx;
}

.cases-hero-sub {
  font-size: 22rpx;
  opacity: 0.6;
  letter-spacing: 4rpx;
}

.cases-grid {
  padding: 24rpx 28rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.case-card {
  position: relative;
  border-radius: 16rpx;
  overflow: hidden;
  aspect-ratio: 3 / 4;
}

.case-img {
  width: 100%;
  height: 100%;
}

.case-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50%;
  background: linear-gradient(transparent, rgba(26,20,18,0.8));
}

.case-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
}

.case-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.case-desc {
  font-size: 20rpx;
  color: rgba(255,255,255,0.75);
}

.cases-tip {
  text-align: center;
  padding: 32rpx;
  font-size: 24rpx;
  color: #9E8A82;
}

.safe-bottom { height: 40rpx; }
