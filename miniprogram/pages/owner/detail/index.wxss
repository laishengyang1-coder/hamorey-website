/* 电子质保卡详情 — 高级质感版 */

.detail-page {
  position: relative;
  min-height: 100vh;
  background: #1A1412;
}

.detail-bg {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
  filter: brightness(0.35);
}

.detail-bg-overlay {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(180deg, rgba(26,20,18,0.6) 0%, rgba(26,20,18,0.85) 40%, rgba(26,20,18,0.95) 100%);
  z-index: 1;
}

.detail-scroll {
  position: relative;
  z-index: 2;
  height: 100vh;
  padding-bottom: env(safe-area-inset-bottom);
}

/* 加载 / 错误 */
.loading-container, .error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 200rpx 32rpx;
}

.loading-spinner {
  width: 48rpx; height: 48rpx;
  border: 3rpx solid rgba(255,255,255,0.15);
  border-top-color: #C8A96E;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}
@keyframes spin { to { transform: rotate(360deg); } }

.loading-text { font-size: 28rpx; color: rgba(255,255,255,0.5); }
.error-text { font-size: 28rpx; color: rgba(255,255,255,0.7); margin-bottom: 24rpx; }

.retry-btn {
  padding: 16rpx 48rpx;
  background: rgba(200,169,110,0.2);
  color: #C8A96E;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: 1rpx solid rgba(200,169,110,0.3);
}

/* 质保卡头部 */
.cert-header {
  text-align: center;
  padding: 48rpx 32rpx 32rpx;
}

.cert-badge {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.cert-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
  margin-bottom: 8rpx;
}

.cert-no {
  font-size: 24rpx;
  color: rgba(255,255,255,0.5);
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.cert-status {
  display: inline-block;
  padding: 8rpx 28rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.tag-success {
  background: rgba(200,169,110,0.2);
  color: #C8A96E;
  border: 1rpx solid rgba(200,169,110,0.3);
}

/* 信息卡片 */
.info-card {
  margin: 0 28rpx 20rpx;
  background: rgba(255,255,255,0.06);
  backdrop-filter: blur(20rpx);
  -webkit-backdrop-filter: blur(20rpx);
  border-radius: 20rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255,255,255,0.08);
}

.card-title {
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(200,169,110,0.8);
  letter-spacing: 2rpx;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid rgba(255,255,255,0.06);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.45);
  flex-shrink: 0;
  width: 140rpx;
}

.info-value {
  font-size: 26rpx;
  color: rgba(255,255,255,0.85);
  text-align: right;
  flex: 1;
}

.info-value.strong { font-weight: 700; color: #FFFFFF; }
.info-value.accent { font-weight: 700; color: #C8A96E; }

/* 施工照片 */
.photos-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.photo-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  background: rgba(255,255,255,0.05);
}

/* 部位报价入口 */
.quote-btn {
  margin: 16rpx 28rpx 32rpx;
  padding: 24rpx 28rpx;
  background: rgba(200,169,110,0.12);
  border: 1rpx solid rgba(200,169,110,0.25);
  border-radius: 16rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  color: #C8A96E;
}

.arrow { font-size: 32rpx; }

.safe-bottom { height: 40rpx; }
