<view class="detail-page">
  <!-- 背景图 -->
  <image class="detail-bg" src="/images/home-bg.jpg" mode="aspectFill" />
  <view class="detail-bg-overlay"></view>

  <!-- 内容层 -->
  <scroll-view class="detail-scroll" scroll-y="true" enhanced="true" show-scrollbar="false">
    <!-- Loading -->
    <view wx:if="{{loading}}" class="loading-container">
      <view class="loading-spinner"></view>
      <view class="loading-text">加载中...</view>
    </view>

    <!-- Error -->
    <view wx:elif="{{error}}" class="error-container">
      <view class="error-text">{{error}}</view>
      <view class="retry-btn" bindtap="loadData">重试</view>
    </view>

    <!-- 质保卡详情 -->
    <block wx:else>
      <!-- 质保卡头部 -->
      <view class="cert-header">
        <view class="cert-badge">🛡️</view>
        <view class="cert-title">电子质保卡</view>
        <view class="cert-no">NO. {{record.certificate_no || record.id}}</view>
        <view class="cert-status tag-success">保障中</view>
      </view>

      <!-- 产品信息卡片 -->
      <view class="info-card">
        <view class="card-title">质保信息</view>
        <view class="info-row"><text class="info-label">产品名称</text><text class="info-value strong">{{record.product_name_snapshot || '--'}}</text></view>
        <view class="info-row"><text class="info-label">产品型号</text><text class="info-value">{{record.product_model_snapshot || record.model_name || '--'}}</text></view>
        <view class="info-row"><text class="info-label">质保年限</text><text class="info-value">{{record.warranty_years_snapshot || '--'}} 年</text></view>
        <view class="info-row"><text class="info-label">质保价格</text><text class="info-value accent">{{record.warranty_price_text || '--'}}</text></view>
        <view class="info-row"><text class="info-label">质保码</text><text class="info-value">{{record.warranty_code || '--'}}</text></view>
        <view class="info-row"><text class="info-label">施工日期</text><text class="info-value">{{record.installation_date || '--'}}</text></view>
        <view class="info-row"><text class="info-label">到期日期</text><text class="info-value accent">{{record.warranty_expiry_date || '--'}}</text></view>
      </view>

      <!-- 车辆信息 -->
      <view class="info-card">
        <view class="card-title">车辆信息</view>
        <view class="info-row"><text class="info-label">车牌号</text><text class="info-value">{{record.plate_no_snapshot || '--'}}</text></view>
        <view class="info-row"><text class="info-label">车架号</text><text class="info-value">{{record.vin_snapshot || '--'}}</text></view>
        <view class="info-row"><text class="info-label">品牌</text><text class="info-value">{{record.vehicle_brand_snapshot || '--'}}</text></view>
        <view class="info-row"><text class="info-label">型号</text><text class="info-value">{{record.vehicle_model_snapshot || '--'}}</text></view>
      </view>

      <!-- 施工门店 -->
      <view class="info-card">
        <view class="card-title">施工门店</view>
        <view class="info-row"><text class="info-label">门店名称</text><text class="info-value">{{record.store_name_snapshot || '--'}}</text></view>
      </view>

      <!-- 施工照片 -->
      <view wx:if="{{recordPhotos.length > 0}}" class="info-card">
        <view class="card-title">施工照片</view>
        <view class="photos-grid">
          <image
            wx:for="{{recordPhotos}}" wx:key="id"
            src="{{item.url || item.file_key}}" mode="aspectFill"
            class="photo-item" data-url="{{item.url || item.file_key}}" bindtap="previewPhoto"
          />
        </view>
      </view>

      <!-- 部位报价入口 -->
      <view class="quote-btn" bindtap="goQuote">
        <text>📊 查看部位理赔报价</text>
        <text class="arrow">›</text>
      </view>

      <view class="safe-bottom"></view>
    </block>
  </scroll-view>
</view>
