.warranty-page {
  position: relative;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  background: #000000;
  overflow: hidden;
}

.page-bg-swiper {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 0;
  background: #000000;
}

.page-bg-swiper .page-bg {
  width: 100%;
  height: 100%;
}

.page-bg-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
  z-index: 1;
  background: linear-gradient(
    180deg,
    rgba(44, 20, 18, 0.55) 0%,
    rgba(44, 20, 18, 0.25) 35%,
    rgba(44, 20, 18, 0.72) 70%,
    rgba(44, 20, 18, 0.9) 100%
  );
}

.page-content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  padding-top: 48rpx;
}

.brand-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 48rpx 20rpx;
}

.brand-logo-img {
  width: 320rpx;
  height: 95rpx;
  margin-bottom: 16rpx;
}

.brand-slogan {
  font-size: 32rpx;
  font-weight: 400;
  color: #FFFFFF;
  letter-spacing: 6rpx;
  margin-bottom: 10rpx;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.5);
}

.brand-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 3rpx;
}

.search-section {
  padding: 0 60rpx;
  margin-top: 36vh;
}

.search-card {
  background: #FFFFFF;
  border-radius: 999rpx;
  padding: 8rpx 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.2);
}

.search-input {
  width: 100%;
  height: 64rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #2C2C2C;
  text-align: center;
}

.search-placeholder {
  color: #AAAAAA;
  font-size: 24rpx;
  text-align: center;
}

.search-btn {
  margin-top: 20rpx;
  width: 100%;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: var(--color-primary);
  border-radius: 999rpx;
  box-shadow: 0 6rpx 18rpx rgba(92, 26, 26, 0.35);
}

.search-btn:active {
  opacity: 0.9;
}

.search-btn-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.search-hint {
  text-align: center;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-top: 16rpx;
}

.footer-section {
  background: rgba(0, 0, 0, 0.38);
  padding: 36rpx 48rpx 36rpx;
  margin-top: auto;
  margin-bottom: 40rpx;
}

.store-entry {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 14rpx 0;
  margin-top: 24rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 12rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.1);
}

.store-entry-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.store-entry-text {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
}

.store-entry-arrow {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-left: 6rpx;
}

.brand-footer {
  display: flex;
  justify-content: center;
}

.brand-footer-text {
  font-size: 18rpx;
  color: rgba(255, 255, 255, 0.28);
  letter-spacing: 2rpx;
}

.safe-bottom-placeholder {
  height: 140rpx;
}
