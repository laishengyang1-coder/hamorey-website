.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 140rpx;
}

.submit-area {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: var(--color-bg-white);
  box-shadow: 0 -2rpx 12rpx rgba(0,0,0,0.06);
}

.search-placeholder { color: var(--color-text-placeholder); font-size: var(--font-md); }
