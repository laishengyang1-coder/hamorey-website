<view class="page-container">
  <view class="filter-bar">
    <view class="filter-search">
      <input class="filter-input" placeholder="搜索质保码" placeholder-class="search-placeholder" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="onSearch"/>
    </view>
    <view class="filter-tabs">
      <view wx:for="{{statusTabs}}" wx:key="value" class="filter-tab {{activeStatus === item.value ? 'active' : ''}}" data-value="{{item.value}}" bindtap="switchStatus">{{item.label}}</view>
    </view>
  </view>

  <view wx:if="{{loading}}" class="loading-container"><view class="loading-spinner"></view></view>
  <view wx:elif="{{error}}" class="error-container">
    <view class="error-text">{{error}}</view>
    <view class="btn-primary btn-sm" style="width:240rpx" bindtap="loadCodes">重试</view>
  </view>
  <view wx:elif="{{!loading && codes.length === 0}}" class="empty-state">
    <view class="empty-state-icon"></view>
    <view class="empty-state-text">暂无质保码</view>
  </view>

  <view wx:else class="codes-list">
    <view wx:for="{{codes}}" wx:key="id" class="code-card card" data-id="{{item.id}}" data-checked="{{item.checked}}">
      <view class="code-top">
        <view class="code-value">{{item.code || '--'}}</view>
        <view class="tag {{statusTagClass(item.status)}}">{{statusLabel(item.status)}}</view>
      </view>
      <view class="code-meta">
        <text>型号：{{item.model_name || item.display_name || '--'}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{hasMore && codes.length > 0}}" class="load-more" bindtap="loadMore">
    <text class="load-more-text">{{loadingMore ? '加载中...' : '加载更多'}}</text>
  </view>
</view>
