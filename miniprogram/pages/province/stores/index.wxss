.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 160rpx;
}

.store-card {
  margin-bottom: 8rpx;
  position: relative;
}

.store-name {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
}

.store-meta {
  display: flex;
  justify-content: space-between;
  font-size: var(--font-xs);
  color: var(--color-text-light);
  margin-bottom: 8rpx;
}

.store-contact {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  display: flex;
  gap: 16rpx;
}

.store-status {
  position: absolute;
  top: 32rpx;
  right: 32rpx;
}

.float-btn {
  position: fixed;
  bottom: 48rpx;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
}

.float-btn-text {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 48rpx;
  background: var(--color-accent);
  color: #2C2C2C;
  font-size: var(--font-md);
  font-weight: 600;
  border-radius: var(--radius-round);
  box-shadow: 0 8rpx 24rpx rgba(200, 169, 110, 0.4);
}
