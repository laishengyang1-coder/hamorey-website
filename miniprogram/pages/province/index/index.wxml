<view class="page-container">
  <!-- 省代头部 -->
  <view class="store-header">
    <view class="brand-line">和膜 HAMOREY</view>
    <view class="store-name">{{provinceName}}</view>
    <view class="store-meta">省级代理商</view>
  </view>

  <!-- 数据概览 -->
  <view class="stats-row">
    <view class="stat-card" bindtap="goStores">
      <view class="stat-value">{{dashboard.storeCount}}</view>
      <view class="stat-label">下属门店</view>
    </view>
    <view class="stat-card" bindtap="goCodes">
      <view class="stat-value">{{dashboard.codeCount}}</view>
      <view class="stat-label">可用质保码</view>
    </view>
    <view class="stat-card" bindtap="goPoints">
      <view class="stat-value">{{dashboard.availablePoints}}</view>
      <view class="stat-label">可用积分</view>
    </view>
  </view>

  <!-- 更多数据 -->
  <view class="mini-stats">
    <view class="mini-stat">
      <view class="mini-value">{{dashboard.recordCount}}</view>
      <view class="mini-label">质保记录</view>
    </view>
    <view class="mini-stat">
      <view class="mini-value {{dashboard.pendingCount > 0 ? 'text-warning' : ''}}">{{dashboard.pendingCount}}</view>
      <view class="mini-label">待审核</view>
    </view>
    <view class="mini-stat">
      <view class="mini-value text-accent">{{dashboard.todayRecords}}</view>
      <view class="mini-label">今日新增</view>
    </view>
    <view class="mini-stat">
      <view class="mini-value">{{dashboard.frozenPoints}}</view>
      <view class="mini-label">冻结积分</view>
    </view>
  </view>

  <!-- 排行 -->
  <view class="rank-section">
    <view class="section-title">门店质保排行</view>
    <view class="rank-card" wx:if="{{storeRanking.length > 0}}">
      <view class="rank-item" wx:for="{{storeRanking}}" wx:key="name">
        <view class="rank-index {{index < 3 ? 'rank-top' : ''}}">{{index + 1}}</view>
        <view class="rank-name">{{item.name}}</view>
        <view class="rank-count">{{item.count}}</view>
      </view>
    </view>
    <view class="rank-empty" wx:else>下属门店暂无质保记录</view>
  </view>

  <view class="rank-section">
    <view class="section-title">产品质保排行</view>
    <view class="rank-card" wx:if="{{productRanking.length > 0}}">
      <view class="rank-item" wx:for="{{productRanking}}" wx:key="name">
        <view class="rank-index {{index < 3 ? 'rank-top' : ''}}">{{index + 1}}</view>
        <view class="rank-name">{{item.name}}</view>
        <view class="rank-count">{{item.count}}</view>
      </view>
    </view>
    <view class="rank-empty" wx:else>暂无产品质保记录</view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-actions">
    <view class="section-title mb-24">快捷操作</view>
    <view class="action-grid">
      <view class="action-item" bindtap="goStores">
        <image class="action-icon" src="/images/tab-store-active.png" mode="aspectFit" />
        <view class="action-text">下属门店</view>
      </view>
      <view class="action-item" bindtap="goCodes">
        <image class="action-icon" src="/images/tab-code-active.png" mode="aspectFit" />
        <view class="action-text">质保码库存</view>
      </view>
      <view class="action-item" bindtap="goAllocate">
        <image class="action-icon" src="/images/icon-allocate.png" mode="aspectFit" />
        <view class="action-text">划拨质保码</view>
      </view>
      <view class="action-item" bindtap="goPoints">
        <image class="action-icon" src="/images/tab-points-active.png" mode="aspectFit" />
        <view class="action-text">积分管理</view>
      </view>
      <view class="action-item" bindtap="goRewards">
        <image class="action-icon" src="/images/icon-gift.png" mode="aspectFit" />
        <view class="action-text">积分商城</view>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-wrap">
    <view class="logout-btn" bindtap="handleLogout">退出登录</view>
  </view>
</view>
