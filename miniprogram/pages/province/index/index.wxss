.page-container {
  min-height: 100vh;
  background: var(--color-bg);
  padding-bottom: 140rpx;
}

/* 省代头部 */
.store-header {
  background: linear-gradient(135deg, #5C1A1A 0%, #7A2E2E 100%);
  padding: 48rpx 32rpx 56rpx;
  color: #FFFFFF;
}

.brand-line {
  font-size: 24rpx;
  letter-spacing: 4rpx;
  color: rgba(255, 255, 255, 0.55);
  margin-bottom: 16rpx;
}

.store-name {
  font-size: var(--font-xl);
  font-weight: 700;
  margin-bottom: 8rpx;
}

.store-meta {
  font-size: var(--font-sm);
  color: rgba(255, 255, 255, 0.7);
}

/* 数据概览 */
.stats-row {
  display: flex;
  margin: -32rpx 24rpx 24rpx;
  position: relative;
  z-index: 1;
}

.stat-card {
  flex: 1;
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: 28rpx 16rpx;
  text-align: center;
  margin: 0 8rpx;
  box-shadow: var(--shadow-md);
}

.stat-value {
  font-size: var(--font-xxl);
  font-weight: 700;
  color: var(--color-primary);
}

.stat-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

/* 更多数据 */
.mini-stats {
  display: flex;
  margin: 0 24rpx 24rpx;
}

.mini-stat {
  flex: 1;
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  padding: 24rpx 12rpx;
  text-align: center;
  margin: 0 8rpx;
  box-shadow: var(--shadow-sm);
}

.mini-value {
  font-size: var(--font-xl);
  font-weight: 700;
  color: var(--color-primary);
}

.mini-label {
  font-size: var(--font-xs);
  color: var(--color-text-secondary);
  margin-top: 6rpx;
}

/* 快捷入口 */
.quick-actions {
  margin: 24rpx;
}

.action-grid {
  display: flex;
  flex-wrap: wrap;
  background: var(--color-bg-white);
  border-radius: var(--radius-md);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
}

.action-item {
  width: 33.33%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 36rpx 0;
  border-right: 1rpx solid var(--color-border-light);
  border-bottom: 1rpx solid var(--color-border-light);
}

.action-item:nth-child(3n) {
  border-right: none;
}

.action-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 14rpx;
}

.action-text {
  font-size: var(--font-sm);
  color: var(--color-text);
}

/* 退出按钮 */
.logout-wrap {
  padding: 24rpx 48rpx 48rpx;
}

.logout-btn {
  text-align: center;
  padding: 24rpx;
  border-radius: var(--radius-md);
  border: 1rpx solid var(--color-border);
  background: var(--color-bg-white);
  color: var(--color-text-secondary);
  font-size: var(--font-sm);
}
