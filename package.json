{
  "name": "hamorey-website-v1",
  "private": true,
  "version": "1.0.0",
  "description": "和膜 HAMOREY 官网与质保系统 V1 — 品牌官网 + 数据层基座 + 后台管理",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:full": "wrangler pages dev . --port 8788",
    "build": "npm run test:contracts && tsc -p tsconfig.functions.json --noEmit && tsc -b && vite build && node scripts/check-spa-build.mjs",
    "preview": "vite preview",
    "db:init": "wrangler d1 execute hamorey-db --local --file=./schema.sql",
    "db:migrate": "wrangler d1 execute hamorey-db --local --file=./migrations/phase2.sql",
    "db:migrate:hardening": "wrangler d1 execute hamorey-db --local --file=./migrations/phase3_hardening.sql",
    "db:migrate:company-fields": "wrangler d1 execute hamorey-db --local --file=./migrations/phase4_organization_company_fields.sql",
    "db:migrate:legacy-warranty": "wrangler d1 execute hamorey-db --local --file=./migrations/phase5_legacy_warranty_support.sql",
    "db:migrate:window-film": "wrangler d1 execute hamorey-db --local --file=./migrations/phase6_window_film_catalog.sql",
    "db:migrate:warranty-price-usage": "wrangler d1 execute hamorey-db --local --file=./migrations/phase7_warranty_price_usage_limits.sql",
    "db:migrate:recalculate-code-usage": "wrangler d1 execute hamorey-db --local --file=./migrations/phase8_recalculate_code_usage_counts.sql",
    "db:migrate:align-points-rules": "wrangler d1 execute hamorey-db --local --file=./migrations/phase9_align_points_rules_to_active_models.sql",
    "db:seed": "wrangler d1 execute hamorey-db --local --file=./seed.sql",
    "db:init:remote": "wrangler d1 execute hamorey-db --file=./schema.sql",
    "db:migrate:remote": "wrangler d1 execute hamorey-db --file=./migrations/phase2.sql",
    "db:migrate:hardening:remote": "wrangler d1 execute hamorey-db --remote --file=./migrations/phase3_hardening.sql",
    "db:migrate:company-fields:remote": "wrangler d1 execute hamorey-db --remote --file=./migrations/phase4_organization_company_fields.sql",
    "db:migrate:legacy-warranty:remote": "wrangler d1 execute hamorey-db --remote --file=./migrations/phase5_legacy_warranty_support.sql",
    "db:migrate:window-film:remote": "wrangler d1 execute hamorey-db --remote --file=./migrations/phase6_window_film_catalog.sql",
    "db:migrate:warranty-price-usage:remote": "wrangler d1 execute hamorey-db --remote --file=./migrations/phase7_warranty_price_usage_limits.sql",
    "db:migrate:recalculate-code-usage:remote": "wrangler d1 execute hamorey-db --remote --file=./migrations/phase8_recalculate_code_usage_counts.sql",
    "db:migrate:align-points-rules:remote": "wrangler d1 execute hamorey-db --remote --file=./migrations/phase9_align_points_rules_to_active_models.sql",
    "db:seed:remote": "wrangler d1 execute hamorey-db --file=./seed.sql",
    "deploy": "npm run build && wrangler pages deploy dist",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:contracts",
    "test:contracts": "node scripts/check-api-contracts.mjs",
    "test:spa-build": "node scripts/check-spa-build.mjs"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-tooltip": "^1.1.2",
    "clsx": "^2.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "tailwind-merge": "^2.4.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260702.1",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.3",
    "vite": "^8.1.4",
    "wrangler": "4.102.0"
  }
}
