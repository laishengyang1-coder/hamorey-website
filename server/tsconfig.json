{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node", "@cloudflare/workers-types"]
  },
  "include": ["src/**/*.ts", "../functions/api/**/*.ts"]
}
